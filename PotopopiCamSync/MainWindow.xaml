<Window x:Class="PotopopiCamSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potopopi CamSync Dashboard" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="850" Background="#F4F7F9" Icon="/Assets/icon.png">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <Border Background="#2C3E50" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="POTOPOPI CAMSYNC" FontSize="20" FontWeight="ExtraBold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Ellipse Width="8" Height="8" Fill="{Binding IsSyncing, Converter={StaticResource BoolToVis}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#BDC3C7" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Settings" Click="Settings_Click" Width="100" Padding="8" Background="#34495E" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
                    <Button Content="Exit" Click="Hide_Click" Width="80" Padding="8" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cloud Selection Bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,0,0,1" Padding="20,10" VerticalAlignment="Top" Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sync Destinations:" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="#2C3E50"/>
                
                <CheckBox Content="Local Folder" IsChecked="True" IsEnabled="False" Margin="0,0,20,0" VerticalAlignment="Center"/>
                
                <CheckBox Content="Immich" IsChecked="{Binding IsImmichSelected}" IsEnabled="{Binding ImmichConfigured}" Margin="0,0,20,0" VerticalAlignment="Center"
                          ToolTip="Upload to your Immich server (Configured in Settings)"/>
                
                <CheckBox Content="Google Drive" IsChecked="{Binding IsGoogleDriveSelected}" IsEnabled="{Binding GoogleDriveAuthenticated}" Margin="0,0,20,0" VerticalAlignment="Center"
                          ToolTip="Upload to Google Drive (Login in Settings)"/>
                
                <CheckBox Content="OneDrive" IsChecked="{Binding IsOneDriveSelected}" IsEnabled="{Binding OneDriveAuthenticated}" Margin="0,0,20,0" VerticalAlignment="Center"
                          ToolTip="Upload to OneDrive (Login in Settings)"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <!-- Tab Content -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10,45,10,0">
            <!-- DASHBOARD TAB -->
            <TabItem Header="Sync Dashboard">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Device Management -->
                    <ScrollViewer Grid.Column="0" Margin="0,0,20,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Active Devices" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#2C3E50"/>
                            <ItemsControl ItemsSource="{Binding ActiveDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#DCDDE1" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15" Foreground="#2F3640"/>
                                                    <TextBlock Text="Registered &amp; Connected" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Sync" Command="{Binding DataContext.ManualSyncCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                            Width="60" Padding="5" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,5,0"/>
                                                    <Button Content="Force" Command="{Binding DataContext.ForceSyncCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                            Width="50" Padding="5" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0" ToolTip="Force verify all files and re-download missing/incomplete files"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="New Devices Found" FontWeight="Bold" FontSize="16" Margin="0,15,0,12" Foreground="#2C3E50" 
                                       Visibility="{Binding UnregisteredDevices.Count, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding UnregisteredDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#EBEEF1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                <Button Grid.Column="1" Content="Register" Command="{Binding DataContext.RegisterDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                        Padding="10,5" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right: Activity Logs -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Activity Log" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#2C3E50"/>
                        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#DCDDE1" BorderThickness="1">
                            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent" Padding="10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas" Foreground="#34495E" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- AI REVIEW TAB -->
            <TabItem Header="AI Review">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="AI Analysis Results" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Flagged files (blurry or duplicate) are kept here until you allow them to sync or delete them." Foreground="#7F8C8D"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#DCDDE1" BorderThickness="1">
                        <ListView ItemsSource="{Binding FlaggedFiles}" BorderThickness="0" Background="Transparent" MouseDoubleClick="ListView_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="40">
                                        <GridViewColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox ToolTip="Select All" Command="{Binding DataContext.ToggleSelectAllCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                          CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}" />
                                            </DataTemplate>
                                        </GridViewColumn.HeaderTemplate>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Reason" Width="100">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FF7675"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Reason}" Value="Duplicate">
                                                                    <Setter Property="Background" Value="#FDCB6E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Reason}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Action" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Command="{Binding DataContext.AllowImmichSyncCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" Width="80" Margin="0,0,5,0" Foreground="White" BorderThickness="0" Padding="5,2" FontWeight="Bold">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Content" Value="Allow Sync"/>
                                                                <Setter Property="Background" Value="#FDCB6E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAllowed}" Value="True">
                                                                        <Setter Property="Content" Value="Allowed"/>
                                                                        <Setter Property="Background" Value="#00B894"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.ToggleDeleteLocalCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" Width="80" Foreground="White" BorderThickness="0" Padding="5,2" FontWeight="Bold">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Content" Value="Delete Local"/>
                                                                <Setter Property="Background" Value="#95A5A6"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPendingDeletion}" Value="True">
                                                                        <Setter Property="Content" Value="To Delete"/>
                                                                        <Setter Property="Background" Value="#E74C3C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="File Name" DisplayMemberBinding="{Binding FileName}" Width="200"/>
                                    <GridViewColumn Header="Full Path" DisplayMemberBinding="{Binding Path}" Width="350"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Allow Selected" Command="{Binding AllowSelectedImmichSyncCommand}" Padding="15,8" Margin="0,0,10,0" Background="#00B894" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Revoke Selected" Command="{Binding RevokeSelectedImmichSyncCommand}" Padding="15,8" Margin="0,0,10,0" Background="#E67E22" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Delete Selected Local" Command="{Binding DeleteSelectedLocalCommand}" Padding="15,8" Margin="0,0,10,0" Background="#EB4D4B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Open Local Folder" Command="{Binding OpenLocalFolderCommand}" Padding="15,8" Background="#BDC3C7" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel VerticalAlignment="Center">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding SyncProgressPercentage}" Height="12" Foreground="#27AE60" Background="#ECF0F1" BorderThickness="0"
                                 Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock Text="{Binding SyncProgressPercentage, StringFormat={}{0:F0}% Complete}" FontSize="10" 
                                   Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text=" | Built with ❤️" FontSize="10" Foreground="#BDC3C7" Margin="5,0,0,0">
                            <TextBlock.ToolTip>
                                <ToolTip Content="AI from Antigravity and Copilot"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                    <Button Content="Sync to Cloud" Command="{Binding SyncLocalToImmichCommand}" Padding="15,8" Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0"
                            Visibility="{Binding IsCloudConfigured, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Open Folder" Command="{Binding OpenLocalFolderCommand}" Padding="15,8" Background="#BDC3C7" Foreground="#2C3E50" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
