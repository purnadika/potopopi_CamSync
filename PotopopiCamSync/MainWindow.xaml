<Window x:Class="PotopopiCamSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potopopi CamSync Dashboard" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="850" Background="#F4F7F9" Icon="/Assets/icon.png">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <Border Background="#2C3E50" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="POTOPOPI CAMSYNC" FontSize="20" FontWeight="ExtraBold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Ellipse Width="8" Height="8" Fill="{Binding IsSyncing, Converter={StaticResource BoolToVis}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#BDC3C7" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Settings" Click="Settings_Click" Width="100" Padding="8" Background="#34495E" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
                    <Button Content="Exit" Click="Hide_Click" Width="80" Padding="8" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Device Management & Analysis -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Active Devices" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#2C3E50"/>
                
                <ItemsControl ItemsSource="{Binding ActiveDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#DCDDE1" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="Bold" FontSize="15" Foreground="#2F3640"/>
                                        <TextBlock Text="Registered &amp; Connected" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Sync" Command="{Binding DataContext.ManualSyncCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                            Width="80" Padding="5" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="New Devices Found" FontWeight="Bold" FontSize="16" Margin="0,15,0,12" Foreground="#2C3E50" 
                           Visibility="{Binding UnregisteredDevices.Count, Converter={StaticResource BoolToVis}}"/>
                
                <ItemsControl ItemsSource="{Binding UnregisteredDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#EBEEF1" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DeviceName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="1" Content="Register" Command="{Binding DataContext.RegisterDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                            Padding="10,5" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Analysis Summary (Premium UX) -->
                <Border Background="#DFF9FB" CornerRadius="8" Padding="15" Margin="0,20,0,0" BorderBrush="#7ED6DF" BorderThickness="1"
                        Visibility="{Binding ShowAnalysisResults, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="AI Analysis Results" FontWeight="Bold" Foreground="#130F40" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Blurry Photos" Foreground="#7F8C8D" FontSize="12"/>
                                <TextBlock Text="{Binding BlurryCount}" FontSize="24" FontWeight="Bold" Foreground="#EB4D4B"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Duplicates" Foreground="#7F8C8D" FontSize="12"/>
                                <TextBlock Text="{Binding DuplicateCount}" FontSize="24" FontWeight="Bold" Foreground="#F0932B"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Review Flagged Files" Command="{Binding ReviewAIResultsCommand}" 
                                Margin="0,15,0,0" Padding="10" Background="#130F40" Foreground="White" 
                                FontWeight="Bold" BorderThickness="0"/>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Activity Log -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Activity Log" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#2C3E50"/>
                <Border Grid.Row="1" Background="#2F3640" CornerRadius="8" Padding="10">
                    <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#DCDDE1" FontFamily="Consolas" FontSize="11" Margin="0,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel VerticalAlignment="Center">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding SyncProgressPercentage}" Height="12" Foreground="#27AE60" Background="#ECF0F1" BorderThickness="0"
                                 Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding SyncProgressPercentage, StringFormat={}{0:F0}% Complete}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                               Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                    <Button Content="Local Sync → Immich" Command="{Binding SyncLocalToImmichCommand}" Padding="15,8" Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0"
                            Visibility="{Binding ImmichConfigured, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Open Folder" Command="{Binding OpenLocalFolderCommand}" Padding="15,8" Background="#BDC3C7" Foreground="#2C3E50" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
