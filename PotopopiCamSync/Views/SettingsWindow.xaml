<Window x:Class="PotopopiCamSync.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Local Sync Settings" FontWeight="Bold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Local Backup Folder:"/>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="txtLocalFolder" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="Browse..." Width="70" Click="BrowseFolder_Click"/>
            </Grid>
            <CheckBox Name="chkDeleteAfter" Content="Delete files from camera/SD after sync" Margin="0,5,0,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Keep files on camera/SD for (days): " VerticalAlignment="Center"/>
                <TextBox Name="txtKeepDays" Width="50" Text="0"/>
                <TextBlock Text=" (0 = forever/immediately)" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Immich Sync Settings" FontWeight="Bold" Margin="0,10,0,5"/>
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <CheckBox Name="chkEnableImmich" Content="Enable Immich Sync" Margin="0,0,0,5"/>
            <TextBlock Text="Immich Server URL (e.g. https://immich.mydomain.com):"/>
            <TextBox Name="txtImmichUrl" Margin="0,5,0,0"/>
            <TextBlock Text="Immich API Key:" Margin="0,5,0,0"/>
            <TextBox Name="txtImmichApiKey" Margin="0,5,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Registered Devices (You can rename them here)" FontWeight="Bold" Margin="0,10,0,5"/>
        <ListBox Grid.Row="5" Name="lstDevices" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Id}" Width="150" Foreground="Gray" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}" Width="150"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
