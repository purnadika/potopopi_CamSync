<Window x:Class="PotopopiCamSync.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="700" Width="600" WindowStartupLocation="CenterOwner" MinHeight="600" MinWidth="500" Icon="/Assets/icon.png">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Local Sync Settings Section -->
        <TextBlock Text="Local Sync Settings" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <StackPanel Margin="0,0,0,0">
                <TextBlock Text="Local Backup Folder:"/>
                <Grid Margin="0,5,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Name="txtLocalFolder" Margin="0,0,8,0" Padding="8"/>
                    <Button Grid.Column="1" Content="Browse..." Width="75" Click="BrowseFolder_Click" Padding="8,4"/>
                </Grid>
                <CheckBox Name="chkDeleteAfter" Content="Delete files from camera/SD after sync" Margin="0,0,0,8" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="Keep files on camera/SD for (days): " VerticalAlignment="Center"/>
                    <TextBox Name="txtKeepDays" Width="60" Text="0" Padding="5,4" Margin="5,0,0,0"/>
                    <TextBlock Text=" (0 = forever/immediately)" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Immich Sync Settings Section -->
        <TextBlock Grid.Row="2" Text="Immich Sync Settings" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <Border Grid.Row="3" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <StackPanel Margin="0,0,0,0">
                <CheckBox Name="chkEnableImmich" Content="Enable Immich Sync" Margin="0,0,0,8" VerticalAlignment="Center"/>
                <TextBlock Text="Immich Server URL (e.g. https://immich.mydomain.com):"/>
                <TextBox Name="txtImmichUrl" Margin="0,5,0,8" Padding="8"/>
                
                <TextBlock Text="Immich API Key:" Margin="0,0,0,5"/>
                <TextBox Name="txtImmichApiKey" Margin="0,0,0,8" Padding="8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Content="Test Connection" Width="110" Click="TestImmichConnection_Click" Padding="8,4" Margin="0,0,10,0"/>
                    <TextBlock Name="txtImmichStatus" Text="" Visibility="Collapsed" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Registered Devices Section -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Registered Devices (Click to rename, use Unregister to remove)" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Refresh List" Width="90" Click="RefreshDevices_Click" Padding="8,4" Margin="8,0,0,0"/>
        </Grid>

        <!-- Devices ListBox with ScrollViewer -->
        <Border Grid.Row="6" BorderBrush="#D0D0D0" BorderThickness="1" Padding="0" Margin="0,0,0,12" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0">
                    <ListBox Name="lstDevices" Margin="0" BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,6" MinHeight="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Device ID (Read-only) -->
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Id}" 
                                               Width="140" 
                                               Foreground="#666666" 
                                               VerticalAlignment="Center" 
                                               TextTrimming="CharacterEllipsis" 
                                               Margin="0,0,12,0"
                                               ToolTip="{Binding Id}"/>

                                    <!-- Device Name (Editable) -->
                                    <TextBox Grid.Column="1" 
                                             Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             Padding="6,4"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"/>

                                    <!-- Unregister Button -->
                                    <Button Grid.Column="2" 
                                            Content="Unregister" 
                                            Width="85" 
                                            Click="UnregisterDevice_Click"
                                            Tag="{Binding Id}"
                                            Padding="8,4"
                                            Background="#FF6B6B"
                                            Foreground="White"
                                            FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Empty state message -->
                <TextBlock Grid.Row="0" 
                           Name="txtNoDevices"
                           Text="No devices registered yet. Connect a camera or SD card reader to register a device."
                           Foreground="#999999"
                           FontSize="12"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"
                           Margin="20"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button Content="Save" Width="85" Margin="0,0,10,0" Click="Save_Click" Padding="8,6" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Content="Cancel" Width="85" Click="Cancel_Click" Padding="8,6"/>
        </StackPanel>
    </Grid>
</Window>
