<Window x:Class="PotopopiCamSync.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading" Width="400" Height="250" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        BorderThickness="0"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Spinner -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock x:Name="SpinnerText" Text="◐" FontSize="48" Foreground="#2196F3" 
                       HorizontalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Text="Initializing..." FontSize="14" 
                   HorizontalAlignment="Center" Foreground="#333" TextAlignment="Center" Margin="0,0,0,10"/>

        <!-- Progress bar -->
        <ProgressBar x:Name="ProgressBar" Height="6" Width="300" Foreground="#2196F3" 
                     Background="#E0E0E0" IsIndeterminate="True" Margin="0,0,0,10"/>

        <!-- Detail -->
        <TextBlock x:Name="DetailText" Text="" FontSize="12" 
                   HorizontalAlignment="Center" Foreground="#666" TextAlignment="Center"/>
    </StackPanel>
</Window>
