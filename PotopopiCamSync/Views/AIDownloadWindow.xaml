<Window x:Class="PotopopiCamSync.Views.AIDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Downloading AI Module" Height="150" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="White" WindowStyle="None">
    <Border BorderBrush="#333" BorderThickness="1" Padding="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Downloading AI Dependencies (45MB)..." FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#E0E0E0"/>
            <ProgressBar x:Name="pbDownload" Height="15" Minimum="0" Maximum="100" Margin="0,0,0,15" Foreground="#007ACC" Background="#333" BorderThickness="0"/>
            <Grid>
                <TextBlock x:Name="txtStatus" Text="Starting..." VerticalAlignment="Center" Foreground="#AAA" FontSize="11"/>
                <Button Content="Cancel" Width="80" HorizontalAlignment="Right" Click="Cancel_Click" 
                        Background="#333" Foreground="White" BorderThickness="0" Padding="5,2"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
